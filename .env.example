# ╔══════════════════════════════════════════════════╗
# ║  Projector — Variables de Entorno                 ║
# ║  Copia este archivo como .env y llena los valores ║
# ║                                                    ║
# ║  cp .env.example .env                              ║
# ╚══════════════════════════════════════════════════╝

# ── Organización de GitHub ──
# Nombre de tu organización en GitHub (requerido para modo hub)
# Ejemplo: condolab-app, mi-empresa, acme-corp
PROJECTOR_ORG=

# ── Directorio del Hub ──
# Ruta donde se creará el hub de proyectos
# Por defecto: ~/Projects/<org-name>
# Ejemplo: /Users/tu-usuario/Projects/condolab-app
PROJECTOR_HUB_DIR=

# ── GitHub Token (opcional) ──
# Si no usas gh CLI, puedes configurar un token personal
# Crea uno en: https://github.com/settings/tokens
# Permisos necesarios: repo, read:org
# Si usas gh CLI autenticado, este valor no es necesario
GITHUB_TOKEN=
